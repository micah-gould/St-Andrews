{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "^/api/auth(?:/(.*))?$",
      "dest": "/api/auth/[...path].ts?path=$1"
    },
    {
      "src": "^/api/saved-states(?:/(.*))?$",
      "dest": "/api/saved-states/[...path].ts?path=$1"
    },
    {
      "src": "^/api/modules/search$",
      "dest": "/api/modules/search.ts"
    },
    {
      "src": "^/api/modules$",
      "dest": "/api/modules.ts"
    },
    {
      "src": "^/api/catalogs$",
      "dest": "/api/catalogs.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*)",
      "dest": "/index.html"
    }
  ]
}
