# --- Database ---
# SQLite for local dev. For production, set this to a Postgres URL (Neon, Supabase, etc.)
DATABASE_URL="file:./dev.db"

# --- App ---
APP_URL="http://localhost:5174"
API_URL="http://localhost:5175"
PORT=5175

# --- JWT / sessions ---
# Generate a strong random secret:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="dev-secret-change-me-please-use-a-long-random-string"
SESSION_DEFAULT_TTL_HOURS=24
SESSION_REMEMBER_TTL_DAYS=7

# --- Google OAuth ---
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:5175/api/auth/google/callback"

# --- Microsoft OAuth ---
# https://portal.azure.com/  →  Microsoft Entra ID  →  App registrations
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_CALLBACK_URL="http://localhost:5175/api/auth/microsoft/callback"
MICROSOFT_TENANT="common"

# --- Email (Resend - free tier 3k/mo) ---
# https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="St Andrews Modules <onboarding@resend.dev>"

# When RESEND_API_KEY is empty, password reset links are logged to the server console.
